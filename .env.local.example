# --- Supabase: pick ONE style ---
#
# A) Dual dev/prod (recommended): set DEBUG_MODE or PROFILE + six *_DEV / *_PROD variables.
# B) Legacy single project: set NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY + SUPABASE_SERVICE_ROLE_KEY only (ignores profile).
#
# DEBUG_MODE=true | 1  → use *_DEV keys
# DEBUG_MODE=false | 0 → use *_PROD keys
# If DEBUG_MODE is unset: use NEXT_PUBLIC_SUPABASE_PROFILE=dev | prod; else default is dev in `next dev` and prod in production build.
#
# Middleware runs on Edge — it cannot read config.json; use env vars only.

# NEXT_PUBLIC_DEBUG_MODE=true

# NEXT_PUBLIC_SUPABASE_PROFILE=dev

NEXT_PUBLIC_SUPABASE_URL_DEV=https://YOUR_DEV_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_DEV=YOUR_DEV_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY_DEV=YOUR_DEV_SERVICE_ROLE_KEY

NEXT_PUBLIC_SUPABASE_URL_PROD=https://YOUR_PROD_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_PROD=YOUR_PROD_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY_PROD=YOUR_PROD_SERVICE_ROLE_KEY

# Legacy single-project (optional; if set, profile / *_DEV / *_PROD are ignored for Supabase URL/key)
# NEXT_PUBLIC_SUPABASE_URL=https://....supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Whoop API
WHOOP_CLIENT_ID=YOUR_WHOOP_CLIENT_ID
WHOOP_CLIENT_SECRET=YOUR_WHOOP_CLIENT_SECRET
WHOOP_WEBHOOK_SECRET=YOUR_WHOOP_WEBHOOK_SECRET

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_EMAIL=mailto:your-email@example.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
