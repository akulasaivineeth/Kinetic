{
  "name": "kinetic",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "uat": "playwright test --config tests/uat/playwright.config.ts",
    "uat:setup": "playwright test --config tests/uat/playwright.config.ts --project=setup --headed",
    "uat:export-auth": "node tests/uat/scripts/export-auth-from-cdp.mjs",
    "uat:smoke": "playwright test --config tests/uat/playwright.config.ts --grep @smoke",
    "db:migrate": "supabase db push",
    "db:backup:prod": "bash scripts/db-backup-prod.sh",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.62.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^1.7.0",
    "next": "^15.1.0",
    "next-pwa": "^2.0.2",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "pg": "^8.20.0",
    "postcss": "^8.4.0",
    "supabase": "^2.85.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
